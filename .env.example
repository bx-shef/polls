# Секрет для HMAC-подписи nonce. Сгенерировать: openssl rand -hex 32
# Приложение должно отказываться стартовать с этим плейсхолдером (фаза деплоя).
NUXT_SURVEY_SIGNING_SECRET=REPLACE_WITH__openssl_rand_hex_32

# Пароль локальной БД — docker-compose требует его явно (без дефолта).
POSTGRES_PASSWORD=CHANGE_ME
# PostgreSQL (см. docker-compose.yml) — заменить пароль на проде
NUXT_DATABASE_URL=postgres://polls:CHANGE_ME@localhost:5432/polls

# Уровень логирования: info | warning | error
NUXT_LOG_LEVEL=info

# Bitrix24 (фаза связки с порталом) — локальное приложение
# NUXT_B24_CLIENT_ID=
# NUXT_B24_CLIENT_SECRET=
