# Секрет HMAC-сессии дашборда контура B и handshake app-фрейма (>= 32 символа).
# openssl rand -hex 32. БЕЗ него прод-дашборд fail-closed (503) — PII клиентов не утечёт.
# Им же подписывается сессия портала в /api/b24/session (один источник правды).
DASHBOARD_AUTH_SECRET=REPLACE_WITH__openssl_rand_hex_32
# Демо-режим: открыть дашборд БЕЗ сессии портала (=1). ТОЛЬКО для показа/теста —
# в проде утечёт PII (имена клиентов/ответственных). Секрет имеет приоритет над флагом.
# DASHBOARD_DEV_OPEN=1

# Пароль локальной БД — docker-compose требует его явно (без дефолта).
POSTGRES_PASSWORD=CHANGE_ME
# PostgreSQL (см. docker-compose.yml) — заменить пароль на проде
NUXT_DATABASE_URL=postgres://polls:CHANGE_ME@localhost:5432/polls
# Тот же адрес для CLI миграций (node-pg-migrate читает DATABASE_URL). Отдельная
# переменная: миграции — это CLI, а не Nuxt-рантайм. Применить: `pnpm migrate up`.
DATABASE_URL=postgres://polls:CHANGE_ME@localhost:5432/polls

# Уровень логирования: info | warning | error
NUXT_LOG_LEVEL=info

# Bitrix24 (фаза связки с порталом) — локальное приложение
# NUXT_B24_CLIENT_ID=
# NUXT_B24_CLIENT_SECRET=

# Ключ шифрования OAuth-токенов Bitrix24 в БД (AES-256-GCM). openssl rand -hex 32
# Приложение падает на старте при пустом/плейсхолдерном/нулевом ключе (loadTokenKey).
NUXT_BITRIX_TOKEN_KEY=REPLACE_WITH__openssl_rand_hex_32

# Маршрутизация опросов по типу сущности Bitrix24 (какой опрос запускает виджет из карточки).
# При отсутствии для сущности — SURVEY_KEY_DEFAULT, иначе встроенный дефолт (csat_postdeal).
# Полный список: SURVEY_KEY_DEAL, SURVEY_KEY_LEAD, SURVEY_KEY_SPA,
#                SURVEY_KEY_CONTACT, SURVEY_KEY_COMPANY, SURVEY_KEY_TASK
# SURVEY_KEY_DEAL=csat_postdeal
# SURVEY_KEY_TASK=csat_task
# SURVEY_KEY_DEFAULT=csat_postdeal

# Каденция keep-alive-рефреша OAuth-токенов (часов). Простаивающий портал иначе теряет
# refresh_token на ~180-й день. Дефолт 24, диапазон [1,168]. Нужен NUXT_B24_CLIENT_ID/SECRET.
# TOKEN_KEEPALIVE_HOURS=24
