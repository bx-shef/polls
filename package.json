{
  "name": "polls",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "description": "Сервис опросов — движок, версионирование и аналитика (ядро)",
