{
  "name": "polls",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "description": "Сервис опросов — движок, версионирование и аналитика (ядро)",
  "scripts": {
    "postinstall": "nuxt prepare",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "verify": "tsx scripts/verify.ts",
    "serve": "tsx scripts/serve.ts",
    "migrate": "node-pg-migrate",
    "check": "pnpm typecheck && pnpm test:cov && pnpm verify",
    "check:boundary": "tsx scripts/check-core-boundary.ts",
    "typecheck:app": "vue-tsc --noEmit -p .nuxt/tsconfig.json",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "nuxt:prepare": "nuxt prepare",
    "visual:install": "playwright install chromium",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@bitrix24/b24jssdk": "^2.0.0",
    "@bitrix24/b24ui-nuxt": "^2.9.0",
    "@nuxtjs/color-mode": "^4.0.1",
    "nuxt": "^4.4.8",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.8",
    "node-pg-migrate": "^8.0.4",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.12"
  }
}
