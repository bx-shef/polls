# Прод-окружение для деплоя на сервер (docker-compose.prod.yml + nginx-proxy).
# Скопировать в .env рядом с compose-файлами на сервере и заполнить. НЕ коммитить.

# Домен приложения (A-запись → ваш сервер). По нему nginx-proxy выпустит TLS-сертификат.
APP_DOMAIN=polls.example.com
# Почта для Let's Encrypt (уведомления о сертификатах).
LETSENCRYPT_EMAIL=admin@example.com

# Секрет HMAC-сессии дашборда контура B и handshake app-фрейма (>= 32). openssl rand -hex 32.
# Без него прод-дашборд fail-closed (503) — PII клиентов не утечёт.
DASHBOARD_AUTH_SECRET=REPLACE_WITH__openssl_rand_hex_32

# Ключ шифрования OAuth-токенов Bitrix24 в БД (AES-256-GCM, 64 hex). openssl rand -hex 32.
# Нужен при связке с порталом (хранение токенов).
NUXT_BITRIX_TOKEN_KEY=REPLACE_WITH__openssl_rand_hex_32

# PostgreSQL — включается в #6 (постоянное хранение). До этого приложение на демо-сторе.
# POSTGRES_PASSWORD=REPLACE_WITH_strong_password
# DATABASE_URL=postgres://polls:REPLACE_WITH_strong_password@db:5432/polls
