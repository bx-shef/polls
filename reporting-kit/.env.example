# Бот для отправки отчётов в Telegram (@BotFather → /newbot → токен).
TG_BOT_TOKEN=123456:AA-replace-with-real-token

# Единственный канал назначения — все отчёты идут сюда.
# Приватный канал/группа — числовой id вида -100...; публичный — @username.
# Бот должен быть в этом канале админом с правом публикации.
TG_CHAT_ID=-1001234567890
