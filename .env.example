# Секрет для HMAC-подписи nonce (openssl rand -hex 32)
NUXT_SURVEY_SIGNING_SECRET=change-me

# PostgreSQL (см. docker-compose.yml)
NUXT_DATABASE_URL=postgres://polls:polls@localhost:5432/polls

# Уровень логирования: info | warning | error
NUXT_LOG_LEVEL=info

# Bitrix24 (фаза связки с порталом) — локальное приложение
# NUXT_B24_CLIENT_ID=
# NUXT_B24_CLIENT_SECRET=
